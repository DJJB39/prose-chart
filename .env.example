# Veritas — environment configuration
#
# Copy to .env.local (do not commit) and fill in.

# Which AI backend composes the report spec.
#   anthropic → direct api.anthropic.com (Claude Sonnet). DEFAULT.
#               This is the model the writing quality was chosen for.
#   gateway   → Lovable AI Gateway (OpenAI-compatible). Documented fallback.
AI_PROVIDER=anthropic

# Required when AI_PROVIDER=anthropic. Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# Optional overrides. The defaults are the current recommended snapshots.
# If you get a 404 "model not found", pin an explicit dated snapshot here.
# ANTHROPIC_MODEL=claude-sonnet-4-5
# GATEWAY_MODEL=openai/gpt-5

# Required when AI_PROVIDER=gateway. Auto-provisioned in Lovable projects.
# LOVABLE_API_KEY=
